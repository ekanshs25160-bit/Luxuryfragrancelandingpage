<div class="page-width">
  <div class="customer login">
    <h1>{{ 'customer.login.title' | t: default: 'Log in' }}</h1>

    {%- form 'customer_login', novalidate: 'novalidate' -%}
      {{ form.errors | default_errors }}

      <div class="field">
        <input
          type="email"
          name="customer[email]"
          id="CustomerEmail"
          autocomplete="email"
          autocorrect="off"
          autocapitalize="off"
          {% if form.errors contains 'form' %}
            aria-invalid="true"
            aria-describedby="CustomerLoginForm-error"
          {% endif %}
          placeholder="{{ 'customer.login.email' | t: default: 'Email' }}"
          required
        >
        <label for="CustomerEmail">{{ 'customer.login.email' | t: default: 'Email' }}</label>
      </div>

      <div class="field">
        <input
          type="password"
          name="customer[password]"
          id="CustomerPassword"
          autocomplete="current-password"
          placeholder="{{ 'customer.login.password' | t: default: 'Password' }}"
          required
        >
        <label for="CustomerPassword">{{ 'customer.login.password' | t: default: 'Password' }}</label>
      </div>

      <div>
        <a href="{{ routes.account_recover_url }}">{{ 'customer.login.forgot_password' | t: default: 'Forgot your password?' }}</a>
      </div>

      <button type="submit">{{ 'customer.login.sign_in' | t: default: 'Sign in' }}</button>
    {%- endform -%}

    <div>
      <a href="{{ routes.account_register_url }}">{{ 'customer.register.create_account' | t: default: 'Create account' }}</a>
    </div>
  </div>
</div>

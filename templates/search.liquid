<div class="page-width">
  <div class="search">
    <h1 class="search__title">
      {% if search.performed %}
        {{- 'templates.search.title' | t: default: 'Search results' }}
      {% else %}
        {{- 'general.search.search' | t: default: 'Search' }}
      {% endif %}
    </h1>

    <form action="{{ routes.search_url }}" method="get" role="search">
      <div class="search__form">
        <input
          type="search"
          name="q"
          value="{{ search.terms | escape }}"
          placeholder="{{ 'general.search.search' | t: default: 'Search' }}"
          aria-label="{{ 'general.search.search' | t: default: 'Search' }}"
        >
        <button type="submit">{{ 'general.search.search' | t: default: 'Search' }}</button>
      </div>
    </form>

    {% if search.performed %}
      {% if search.results_count == 0 %}
        <p>{{ 'templates.search.no_results' | t: terms: search.terms, default: 'No results found.' }}</p>
      {% else %}
        <p>{{ 'templates.search.results_with_count_and_term' | t: terms: search.terms, count: search.results_count, default: 'Search results' }}</p>
        <div class="search-results product-grid">
          {% for result in search.results %}
            <div class="search-result-item">
              <a href="{{ result.url }}">
                {% if result.image %}
                  <img src="{{ result.image | image_url: width: 300 }}" alt="{{ result.image.alt | escape }}" loading="lazy">
                {% endif %}
                <h2>{{ result.title | escape }}</h2>
                {% if result.price %}
                  <p>{{ result.price | money }}</p>
                {% endif %}
              </a>
            </div>
          {% endfor %}
        </div>
        {% render 'pagination', paginate: paginate %}
      {% endif %}
    {% endif %}
  </div>
</div>
